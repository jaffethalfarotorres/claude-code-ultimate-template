# Template .gitignore for SaaS Platform

# Environment variables (IMPORTANT: Never commit secrets!)
.env
.env.local
.env.*.local

# Dependencies
node_modules/
venv/
__pycache__/
*.py[cod]
*$py.class

# Build outputs
dist/
build/
*.egg-info/
.next/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.pytest_cache/
.coverage

# Database
*.db
*.sqlite
*.sqlite3

# Uploads (if any)
uploads/
media/

# Zero-friction automation outputs (IMPORTANT: Privacy!)
pipelines/intake/outbox/
pipelines/intake/*.log

# Temporary files
tmp/
temp/
*.tmp

# Cache
.cache/
.parcel-cache/

# Production config (use environment variables instead)
config/production.json

# Secrets (NEVER COMMIT!)
secrets/
credentials.json
*.pem
*.key

# Backups (keep local only)
archive/backups/*.tar.gz
archive/backups/*.zip

# Personal notes (keep local)
NOTES.md
TODO.md
